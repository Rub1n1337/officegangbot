BOT_CLIENT_ID="<YOUR_BOT_CLIENT_ID>"
BOT_CLIENT_SECRET="<YOUR_BOT_CLIENT_SECRET>"

# The absolute url of the dashboard (Production)
APP_URL="http://localhost:3000"

# The absolute url of the api endpoint of your bot (Production)
NEXT_PUBLIC_API_ENDPOINT="http://localhost:8080"

# Optional: 32+ char random secret. When set, the session cookie (which holds
# the Discord access/refresh tokens) is encrypted at rest (AES-256-GCM). Leave
# unset to keep the previous plaintext behaviour. Changing it logs everyone out.
# SESSION_SECRET="<A_LONG_RANDOM_STRING>"